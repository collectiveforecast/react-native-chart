{
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,

    "jsx": "react-native",

    "module": "ESNext",
    "target": "ES2018",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,

    "declarationMap": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
